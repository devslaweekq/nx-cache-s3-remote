{
  "name": "nx-cache-s3-remote",
  "version": "1.3.2",
  "private": true,
  "description": "Self-hosted Nx remote cache server backed by S3-compatible storage",
  "license": "MIT",
  "author": "devslaweekq",
  "type": "module",
  "scripts": {
    "build": "bash scripts/docker/build.sh",
    "bump": "bash scripts/utils/bump-version.sh",
    "compile": "tsc -p tsconfig.build.json",
    "dev": "nodemon --exec \"node --env-file=.env\" src/server.ts",
    "format": "prettier -w .",
    "push": "bash scripts/docker/push.sh",
    "start": "pm2-runtime start ecosystem.config.cjs",
    "test": "node --test src/**/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1087.0",
    "express": "^5.2.1",
    "pm2": "^7.0.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "nodemon": "^3.1.14",
    "prettier": "^3.9.5",
    "prettier-plugin-packagejson": "^3.0.2",
    "prettier-plugin-sort-json": "^4.2.0",
    "typescript": "^7.0.2"
  },
  "engines": {
    "node": ">=24"
  }
}
