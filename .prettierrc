{
  "$schema": "http://json.schemastore.org/prettierrc",
  "overrides": [
    {
      "files": ["*.js", "*.ts", "*.json", "*.sh", "*.yml", "*.yaml", "*.md"],
      "options": {
        "singleQuote": true,
        "arrowParens": "avoid",
        "trailingComma": "all",
        "tabWidth": 2,
        "useTabs": false
      }
    }
  ],
  "plugins": ["prettier-plugin-packagejson", "prettier-plugin-sort-json"]
}
